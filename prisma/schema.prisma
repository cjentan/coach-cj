generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  name         String
  passwordHash     String
  role             String  @default("user")
  resetToken       String? @map("reset_token")
  resetTokenExpiry DateTime? @map("reset_token_expiry")
  reviewDayOfWeek         Int      @default(0) @map("review_day_of_week")
  reviewTime              String   @default("18:00") @map("review_time")
  reviewDayOfMonth        Int?     @default(1) @map("review_day_of_month")
  analysisTrigger         String   @default("weekly") @map("analysis_trigger")
  analysisTriggerValue    Int      @default(1) @map("analysis_trigger_value")
  onboardingCompleted Boolean @default(false) @map("onboarding_completed")
  llmProvider             String?  @map("llm_provider")
  llmBaseUrl              String?  @map("llm_base_url")
  llmModel                String?  @map("llm_model")
  llmApiKey               String?  @map("llm_api_key")
  locale                  String   @default("en")
  trainingContext         String?  @map("training_context")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  trainingLogs         TrainingLog[]
  raceGoals            RaceGoal[]
  duplicateGroups      DuplicateGroup[]
  bodyMetrics          BodyMetric[]
  weeklyAssessments    WeeklyAssessment[]
  weeklyPlans          WeeklyPlan[]
  fatigueAlerts        FatigueAlert[]
  apiKeys              ApiKey[]
  garminSession        GarminSession?
  corosSession         CorosSession?
  dailyHealth          DailyHealth[]
  analysisReports      AnalysisReport[]
  coachConversations   CoachConversation[]
  coachSuggestions     CoachSuggestion[]

  @@map("users")
}

enum ActivityType {
  run
  ride
  swim
  hike
  walk
  workout
  other
}

enum ActivitySubType {
  // Running
  trail_running
  treadmill
  virtual_run

  // Cycling
  mountain_biking
  gravel_cycling
  road_cycling
  indoor_cycling
  virtual_ride
  handcycle

  // Swimming
  open_water
  lap_swimming

  // Workout
  strength_training
  crossfit
  yoga
  elliptical
  stair_stepper
  pilates

  // Other specific activities
  rock_climbing
  surfing
  stand_up_paddling
  kayaking
  canoeing
  rowing
  ice_skating
  inline_skating
  nordic_skiing
  alpine_skiing
  backcountry_skiing
  snowboarding
  snowshoeing
  soccer
  tennis
  golf
  wheelchair
}

enum ActivitySource {
  strava
  garmin
  coros
  watch_push
  manual
}

enum DuplicateStatus {
  pending
  resolved_merged
  resolved_keep_both
}

model TrainingLog {
  id                  String           @id @default(uuid())
  userId              String           @map("user_id")
  externalId          String?          @map("external_id")
  source              ActivitySource   @default(strava)
  type                ActivityType
  subType             ActivitySubType?
  name                String
  description         String?
  remarks             String?
  coachAnalysis       String?           @map("coach_analysis")
  startDate           DateTime         @map("start_date")
  durationSeconds     Int              @map("duration_seconds")
  distanceMeters      Float?           @map("distance_meters")
  elevationGainMeters Float?           @map("elevation_gain_meters")
  averageHr           Float?           @map("average_hr")
  maxHr               Float?           @map("max_hr")
  averagePower        Float?           @map("average_power")
  normalizedPower     Float?           @map("normalized_power")
  calories            Float?
  tss                 Float?
  workoutType         String?  @map("workout_type")
  rawJson             Json?            @map("raw_json")
  simplifiedTrackPoints Json?          @map("simplified_track_points")
  trackMinLat         Float?           @map("track_min_lat")
  trackMaxLat         Float?           @map("track_max_lat")
  trackMinLng         Float?           @map("track_min_lng")
  trackMaxLng         Float?           @map("track_max_lng")

  duplicateGroupId    String?          @map("duplicate_group_id")
  duplicateGroup      DuplicateGroup?  @relation(fields: [duplicateGroupId], references: [id])
  duplicateStatus     DuplicateStatus? @map("duplicate_status")
  mergedIntoId        String?          @map("merged_into_id")
  mergedInto          TrainingLog?     @relation("DuplicateMerge", fields: [mergedIntoId], references: [id])
  duplicates          TrainingLog[]    @relation("DuplicateMerge")

  createdAt           DateTime         @default(now()) @map("created_at")

  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, externalId, source])
  @@index([userId, startDate])
  @@index([duplicateGroupId])
  @@index([mergedIntoId])
  @@index([userId, trackMinLat, trackMaxLat])
  @@index([userId, trackMinLng, trackMaxLng])
  @@map("training_logs")
}

model DuplicateGroup {
  id              String          @id @default(uuid())
  userId          String          @map("user_id")
  status          DuplicateStatus @default(pending)
  resolution      String?
  keptActivityId  String?         @map("kept_activity_id")
  mergedAt        DateTime?       @map("merged_at")
  createdAt       DateTime        @default(now()) @map("created_at")

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  trainingLogs TrainingLog[]

  @@index([userId, status])
  @@map("duplicate_groups")
}

enum GoalStatus {
  active
  completed
  cancelled
}

enum GoalPriority {
  A
  B
  C
}

model RaceGoal {
  id                  String      @id @default(uuid())
  userId              String      @map("user_id")
  name                String
  raceType            String      @map("race_type")
  targetDate          DateTime    @map("target_date")
  distanceMeters      Float       @map("distance_meters")
  elevationGainMeters Float?      @map("elevation_gain_meters")
  targetTimeSeconds   Int?        @map("target_time_seconds")
  priority            GoalPriority @default(B)
  status              GoalStatus  @default(active)
  notes               String?
  goalStatement       String?  @map("goal_statement")
  courseProfile       Json?    @map("course_profile")
  createdAt           DateTime    @default(now()) @map("created_at")
  updatedAt           DateTime    @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@map("race_goals")
}

model BodyMetric {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  recordedAt DateTime @map("recorded_at")
  weightKg   Float    @map("weight_kg")
  heightCm   Float?   @map("height_cm")
  restingHr  Float?   @map("resting_hr")
  notes      String?
  createdAt  DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, recordedAt])
  @@map("body_metrics")
}

// Weekly snapshot of computed training metrics.
// Upserted by snapshotWeek() after training log mutations.
// Read by /api/dashboard/trends for historical trend charts.
model WeeklyAssessment {
  id                    String   @id @default(uuid())
  userId                String   @map("user_id")
  weekStartDate         DateTime @map("week_start_date")
  acuteTrainingLoad     Float?   @map("acute_training_load")
  chronicTrainingLoad   Float?   @map("chronic_training_load")
  tsb                   Float?
  readinessScore        Int?     @map("readiness_score")
  fitnessScore          Float?   @map("fitness_score")
  fatigueScore          Float?   @map("fatigue_score")
  formScore             Float?   @map("form_score")
  weeklyVolumeMeters    Float?   @map("weekly_volume_meters")
  weeklyElevationMeters Float?   @map("weekly_elevation_meters")
  weeklyDurationSeconds Int?     @map("weekly_duration_seconds")
  goalProgressPct       Json?    @map("goal_progress_pct")
  recommendations       String[]
  rawData               Json?    @map("raw_data")
  createdAt             DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, weekStartDate])
  @@map("weekly_assessments")
}

model WeeklyPlan {
  id                    String   @id @default(uuid())
  userId                String   @map("user_id")
  weekStartDate         DateTime @map("week_start_date")
  generatedAt           DateTime @default(now()) @map("generated_at")
  targetVolumeMeters    Float?   @map("target_volume_meters")
  targetElevationMeters Float?   @map("target_elevation_meters")
  targetDurationSeconds Int?     @map("target_duration_seconds")
  plannedSessions       Json     @map("planned_sessions")
  adjustments           String[]
  trajectoryAssessment  String?  @map("trajectory_assessment")
  coachNotes            String?  @map("coach_notes")
  overridesExisting     Boolean  @default(false) @map("overrides_existing")
  adjustmentHistory     Json?    @map("adjustment_history")
  createdAt             DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, weekStartDate])
  @@index([userId, coachNotes, generatedAt])
  @@map("weekly_plans")
}

enum AlertSeverity {
  low
  medium
  high
  critical
}

model FatigueAlert {
  id                 String        @id @default(uuid())
  userId             String        @map("user_id")
  detectedAt         DateTime      @default(now()) @map("detected_at")
  severity           AlertSeverity
  signals            Json          @default("[]")
  recommendation     String
  recommendedRestDays Int          @default(0) @map("recommended_rest_days")
  acknowledged       Boolean       @default(false)
  createdAt          DateTime      @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, detectedAt])
  @@index([userId, acknowledged, detectedAt])
  @@map("fatigue_alerts")
}

model GarminSession {
  id               String   @id @default(uuid())
  userId           String   @unique @map("user_id")
  oauth1Token      Json     @map("oauth1_token")
  oauth2Token      Json     @map("oauth2_token")
  displayName      String?  @map("display_name")
  garminUserId     Int?     @map("garmin_user_id")
  lastSyncAt       DateTime? @map("last_sync_at")
  lastHealthSyncAt DateTime? @map("last_health_sync_at")
  connectedAt      DateTime @default(now()) @map("connected_at")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("garmin_sessions")
}

model CorosSession {
  id               String   @id @default(uuid())
  userId           String   @unique @map("user_id")
  accessToken      String   @map("access_token")
  corosUserId      String?  @map("coros_user_id")
  displayName      String?  @map("display_name")
  lastSyncAt       DateTime? @map("last_sync_at")
  connectedAt      DateTime @default(now()) @map("connected_at")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("coros_sessions")
}

model DailyHealth {
  id                String   @id @default(uuid())
  userId            String   @map("user_id")
  date              DateTime @map("date")

  // Heart rate
  restingHeartRate  Int?     @map("resting_heart_rate")
  minHeartRate      Int?     @map("min_heart_rate")
  maxHeartRate      Int?     @map("max_heart_rate")

  // Sleep
  sleepSeconds      Int?     @map("sleep_seconds")
  deepSleepSeconds  Int?     @map("deep_sleep_seconds")
  lightSleepSeconds Int?     @map("light_sleep_seconds")
  remSleepSeconds   Int?     @map("rem_sleep_seconds")
  awakeSeconds      Int?     @map("awake_seconds")
  sleepScore        Int?     @map("sleep_score")
  sleepStartLocal   String?  @map("sleep_start_local")
  sleepEndLocal     String?  @map("sleep_end_local")

  // Body Battery
  bodyBatteryMin    Int?     @map("body_battery_min")
  bodyBatteryMax    Int?     @map("body_battery_max")

  // Stress
  avgStress         Int?     @map("avg_stress")
  maxStress         Int?     @map("max_stress")

  // HRV
  hrvBalance        Int?     @map("hrv_balance")
  hrvStatus         String?  @map("hrv_status")
  overnightHrv      Int?     @map("overnight_hrv")

  // Activity
  steps             Int?
  stepGoal          Int?     @map("step_goal")

  // Metadata
  rawData           Json?    @map("raw_data")

  createdAt         DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
  @@map("daily_health")
}

model ApiKey {
  id         String    @id @default(uuid())
  userId     String    @map("user_id")
  name       String
  keyHash    String    @map("key_hash")
  keyPrefix  String    @map("key_prefix")
  lastUsedAt DateTime? @map("last_used_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([keyHash])
  @@map("api_keys")
}

model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @default(now()) @map("updated_at")

  @@map("app_settings")
}

model AnalysisReport {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  reportType    String   @map("report_type")
  triggeredBy   String   @map("triggered_by")
  inputSnapshot Json?    @map("input_snapshot")
  outputContent String?  @map("output_content")
  reasoning     Json?
  metrics       Json?
  createdAt     DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@map("analysis_reports")
}

model CoachConversation {
  id              String   @id @default(uuid())
  userId          String   @map("user_id")
  title           String?
  status          String   @default("active")
  contextSnapshot Json?    @map("context_snapshot")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages    CoachMessage[]
  suggestions CoachSuggestion[]

  @@index([userId, updatedAt(sort: Desc)])
  @@map("coach_conversations")
}

model CoachMessage {
  id              String   @id @default(uuid())
  conversationId  String   @map("conversation_id")
  role            String
  content         String
  suggestionId    String?  @map("suggestion_id")
  tokenCount      Int?     @map("token_count")
  createdAt       DateTime @default(now()) @map("created_at")

  conversation CoachConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("coach_messages")
}

model CoachSuggestion {
  id              String    @id @default(uuid())
  conversationId  String    @map("conversation_id")
  userId          String    @map("user_id")
  suggestionType  String    @map("suggestion_type")
  title           String
  description     String
  changes         Json
  status          String    @default("pending")
  createdAt       DateTime  @default(now()) @map("created_at")
  appliedAt       DateTime? @map("applied_at")

  conversation CoachConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([userId, status])
  @@map("coach_suggestions")
}
